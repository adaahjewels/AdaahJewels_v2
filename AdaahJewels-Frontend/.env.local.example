# =============================================================================
# AdaahJewels Frontend — Environment Variables (Vite)
# Copy this to .env.local — DO NOT commit .env.local to git
# =============================================================================

# Backend API — must match server PORT (default 5000)
VITE_API_BASE_URL=http://localhost:5000/api

# Razorpay public key (same as RAZORPAY_KEY_ID in backend .env)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# Cloudinary (for file uploads direct from browser)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# App metadata
VITE_APP_NAME=AdaahJewels
VITE_APP_DESCRIPTION=Premium Artificial Jewellery
VITE_ENABLE_ADMIN_PANEL=true
VITE_ENABLE_DEBUG_MODE=true
